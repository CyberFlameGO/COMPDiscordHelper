  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/sinon": "^21.0.1",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "mocha": "^11.7.5",
    "pnpm": "^11.1.1",
    "prettier": "^3.8.3",
    "sinon": "^22.0.0",
    "typescript": "^6.0.3",
    "wrangler": "^4.90.1"
